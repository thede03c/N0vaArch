{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/novaarch-logo.txt",
    "color": {
      "1": "red",
      "2": "bright_red"
    }
  },
  "display": {
    "separator": " : "
  },
  "modules": [
    "title",
    "os",
    "kernel",
    "uptime",
    "shell",
    "wm",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "disk",
    "localip",
    "colors"
  ]
}
