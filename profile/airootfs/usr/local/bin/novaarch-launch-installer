#!/usr/bin/env bash
set -euo pipefail

show_info() {
  local msg="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --info --title="NovaArch Installer" --text="${msg}" || true
  else
    echo "${msg}"
  fi
}

show_error() {
  local msg="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --error --title="NovaArch Installer" --text="${msg}" || true
  else
    echo "${msg}" >&2
  fi
}

connectivity="$(nmcli -t -f CONNECTIVITY general 2>/dev/null | head -n1 || echo "unknown")"
if [[ "${connectivity}" == "none" ]]; then
  show_error "No network detected (NetworkManager reports '${connectivity}'). Connect to Wi‑Fi or Ethernet, then try again."
  exit 1
fi

lang_file="${XDG_CONFIG_HOME:-${HOME}/.config}/novaarch/preferred-lang"
if [[ -f "${lang_file}" ]]; then
  selected_lang="$(tr -d '\r\n' < "${lang_file}")"
  [[ -n "${selected_lang}" ]] && export LANG="${selected_lang}"
fi

/usr/local/bin/novaarch-installer-options >/dev/null 2>&1 || true
choices_file="/tmp/novaarch-installer/choices.env"
if [[ -f "${choices_file}" ]]; then
  # shellcheck source=/dev/null
  source "${choices_file}"
  summary="$(printf 'Optional install extras — Browser: %s | VPN: %s | Apps: %s' "${BROWSER_CHOICES:-none}" "${VPN_CHOICES:-none}" "${APP_CHOICES:-none}")"
  command -v notify-send >/dev/null 2>&1 && notify-send "NovaArch" "${summary}" || true
fi

# Calamares is not shipped in vanilla Arch repos; keep this block so custom ISOs can drop a calamares.pkg into a local repo.
if [[ -x /usr/bin/calamares ]] && [[ -f /etc/calamares/settings.conf ]]; then
  if [[ -d /run/archiso ]] && [[ "$(id -un)" == "live" ]] && [[ "$(id -u)" -ne 0 ]]; then
    exec sudo -E /usr/bin/calamares
  fi
  if command -v pkexec >/dev/null 2>&1; then
    exec pkexec /usr/bin/calamares
  fi
  exec /usr/bin/calamares
fi

show_info "$(printf '%s\n%s\n%s\n%s' \
  "NovaArch uses Arch's guided installer (archinstall) in a terminal window." \
  "You will choose language, disks, bootloader, timezone, hostname, username, and password there." \
  "Displays and window behavior: open System Settings (Meta → search Settings) → Workspace or Window Management." \
  "Tip: do not reuse the disposable live login for your installed account password.")"

readonly term_title="NovaArch Install (archinstall)"
readonly inner='status=0; sudo -E archinstall || status=$?;
  if [[ "$status" -ne 0 ]]; then
    printf "\narchinstall exited with status %s. See above for errors.\n" "$status" >&2
  fi
  printf "\nPress Enter to close this window...\n"; read -r _'

if command -v konsole >/dev/null 2>&1; then
  exec konsole --title "${term_title}" -e sh -lc "${inner}"
elif command -v xterm >/dev/null 2>&1; then
  exec xterm -title "${term_title}" -e sh -lc "${inner}"
else
  show_error "No terminal emulator found (konsole, xterm)."
  exit 1
fi
