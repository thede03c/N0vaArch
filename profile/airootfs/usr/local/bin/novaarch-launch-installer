#!/usr/bin/env bash
set -euo pipefail

show_info() {
  local msg="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --info --title="NovaArch Installer" --text="${msg}" || true
  else
    echo "${msg}"
  fi
}

show_error() {
  local msg="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --error --title="NovaArch Installer" --text="${msg}" || true
  else
    echo "${msg}" >&2
  fi
}

connectivity="$(nmcli -t -f CONNECTIVITY general 2>/dev/null || echo "none")"
if [[ "${connectivity}" == "none" || "${connectivity}" == "unknown" ]]; then
  show_error "No network detected. Please connect to Wi-Fi or Ethernet, then try launching the installer again."
  exit 1
fi

lang_file="${XDG_CONFIG_HOME:-${HOME}/.config}/novaarch/preferred-lang"
if [[ -f "${lang_file}" ]]; then
  selected_lang="$(tr -d '\r\n' < "${lang_file}")"
  [[ -n "${selected_lang}" ]] && export LANG="${selected_lang}"
fi

/usr/local/bin/novaarch-installer-options >/dev/null 2>&1 || true
choices_file="/tmp/novaarch-installer/choices.env"
if [[ -f "${choices_file}" ]]; then
  # shellcheck source=/dev/null
  source "${choices_file}"
  summary="Browser: ${BROWSER_CHOICES:-none}\nVPN: ${VPN_CHOICES:-none}\nApps: ${APP_CHOICES:-none}"
  if command -v zenity >/dev/null 2>&1; then
    if ! zenity --question --title="Confirm install selections" --text="Selected options:\n\n${summary}\n\nContinue to installer?"; then
      exit 0
    fi
  else
    echo -e "Selected options:\n${summary}"
  fi
fi

# Calamares is not shipped in vanilla Arch repos; keep this block so custom ISOs can drop a calamares.pkg into a local repo.
if [[ -x /usr/bin/calamares ]] && [[ -f /etc/calamares/settings.conf ]]; then
  if [[ -d /run/archiso ]] && [[ "$(id -un)" == "live" ]] && [[ "$(id -u)" -ne 0 ]]; then
    exec sudo -E /usr/bin/calamares
  fi
  if command -v pkexec >/dev/null 2>&1; then
    exec pkexec /usr/bin/calamares
  fi
  exec /usr/bin/calamares
fi

show_info "$(printf '%s\n%s\n%s' \
  "NovaArch uses Arch's guided installer (archinstall) inside a terminal window." \
  "You will choose language, disks, bootloader, timezone, hostname, username, and password there — after Wi-Fi works." \
  "Tip: do not reuse the disposable live login for your installed account password.")"

exec kitty --title "NovaArch Install (archinstall)" sh -lc "sudo archinstall"
