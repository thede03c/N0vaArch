#!/usr/bin/env bash
set -euo pipefail

if ! command -v kitty >/dev/null 2>&1; then
  echo "kitty is required for updater UI."
  exit 1
fi

kitty --title "NovaArch Updater" sh -lc '
  echo "NovaArch update session"
  echo "----------------------"
  sudo pacman -Syu
  echo
  echo "Press Enter to close..."
  read -r _
'
