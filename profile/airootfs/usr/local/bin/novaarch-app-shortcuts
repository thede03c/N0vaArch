#!/usr/bin/env bash
set -euo pipefail

desktop_dir="${HOME}/Desktop"
pinned_dir="${HOME}/.local/share/novaarch/pinned-apps"
mkdir -p "${desktop_dir}" "${pinned_dir}"

pick_app() {
  local picked
  picked="$(
    rg --files "/usr/share/applications" -g "*.desktop" \
      | sed 's|.*/||' \
      | sort \
      | /usr/local/bin/novaarch-dmenu --prompt "Select app"
  )" || return 1
  [[ -n "${picked:-}" ]] || return 1
  echo "${picked}"
}

add_to_desktop() {
  local app="$1"
  install -Dm755 "/usr/share/applications/${app}" "${desktop_dir}/${app}"
  notify-send "NovaArch" "Added ${app} to Desktop" >/dev/null 2>&1 || true
}

pin_to_taskbar() {
  local app="$1"
  install -Dm755 "/usr/share/applications/${app}" "${pinned_dir}/${app}"
  notify-send "NovaArch" "Saved ${app} to NovaArch pin folder. On KDE you can also drag the app to the panel." >/dev/null 2>&1 || true
}

choice="$(cat <<'EOF' | /usr/local/bin/novaarch-dmenu --prompt 'App Shortcuts'
Add App to Desktop
Pin App (saved copy)
Unpin App from saved copy
Open Desktop Folder
EOF
)" || exit 0
[[ -n "${choice:-}" ]] || exit 0

case "${choice}" in
  "Add App to Desktop")
    app="$(pick_app)" || exit 0
    add_to_desktop "${app}"
    ;;
  "Pin App (saved copy)")
    app="$(pick_app)" || exit 0
    pin_to_taskbar "${app}"
    ;;
  "Unpin App from saved copy")
    app="$(
      rg --files "${pinned_dir}" -g "*.desktop" \
        | sed 's|.*/||' \
        | sort \
        | /usr/local/bin/novaarch-dmenu --prompt "Unpin app"
    )" || exit 0
    [[ -n "${app:-}" ]] || exit 0
    rm -f "${pinned_dir}/${app}"
    ;;
  "Open Desktop Folder")
    if command -v dolphin >/dev/null 2>&1; then
      exec dolphin "${desktop_dir}"
    fi
    exec /usr/local/bin/novaarch-terminal --title "Desktop" -- sh -lc "cd \"${desktop_dir}\" && ${SHELL:-bash}"
    ;;
esac
