#!/usr/bin/env bash
set -euo pipefail

pinned_dir="${HOME}/.local/share/novaarch/pinned-apps"
mkdir -p "${pinned_dir}"

selection="$(
  rg --files "${pinned_dir}" -g "*.desktop" \
    | sed 's|.*/||' \
    | sort \
    | /usr/local/bin/novaarch-dmenu --prompt "Pinned Apps"
)" || exit 0
[[ -n "${selection:-}" ]] || exit 0

desktop_id="${selection}"
exec gtk-launch "${desktop_id}" >/dev/null 2>&1
