#!/usr/bin/env bash
set -euo pipefail

desktop_dir="${HOME}/Desktop"
mkdir -p "${desktop_dir}"

source_file="${1:-}"
if [[ -z "${source_file}" || ! -f "${source_file}" ]]; then
  echo "Usage: novaarch-add-desktop-shortcut /path/to/app.desktop"
  exit 1
fi

if [[ "${source_file}" != *.desktop ]]; then
  echo "Only .desktop files are supported."
  exit 1
fi

target="${desktop_dir}/$(basename "${source_file}")"
install -Dm755 "${source_file}" "${target}"
notify-send "NovaArch" "Added to Desktop: $(basename "${source_file}")" >/dev/null 2>&1 || true
