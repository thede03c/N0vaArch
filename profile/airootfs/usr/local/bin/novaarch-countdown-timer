#!/usr/bin/env python3
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, GLib


class CountdownWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="NovaArch Countdown Timer")
        self.set_default_size(340, 180)
        self.set_border_width(12)
        self.remaining = 0
        self.timer_id = None

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self.add(root)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        self.entry = Gtk.Entry()
        self.entry.set_placeholder_text("Minutes (e.g. 25)")
        row.pack_start(self.entry, True, True, 0)

        start_btn = Gtk.Button(label="Start")
        start_btn.connect("clicked", self.start_timer)
        row.pack_start(start_btn, False, False, 0)

        stop_btn = Gtk.Button(label="Stop")
        stop_btn.connect("clicked", self.stop_timer)
        row.pack_start(stop_btn, False, False, 0)
        root.pack_start(row, False, False, 0)

        self.label = Gtk.Label()
        self.label.set_markup("<span size='xx-large' weight='bold'>00:00</span>")
        root.pack_start(self.label, True, True, 0)

        self.status = Gtk.Label(label="Set minutes and press Start.")
        root.pack_start(self.status, False, False, 0)

    def start_timer(self, _button):
        try:
            minutes = int(self.entry.get_text().strip())
        except ValueError:
            self.status.set_text("Enter a valid number of minutes.")
            return
        if minutes <= 0:
            self.status.set_text("Minutes must be greater than zero.")
            return
        self.remaining = minutes * 60
        self.status.set_text("Timer running...")
        self.update_label()
        if self.timer_id:
            GLib.source_remove(self.timer_id)
        self.timer_id = GLib.timeout_add_seconds(1, self.tick)

    def stop_timer(self, _button):
        if self.timer_id:
            GLib.source_remove(self.timer_id)
            self.timer_id = None
        self.status.set_text("Timer stopped.")

    def tick(self):
        if self.remaining <= 0:
            self.label.set_markup("<span size='xx-large' weight='bold'>00:00</span>")
            self.status.set_text("Time is up.")
            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.INFO,
                buttons=Gtk.ButtonsType.OK,
                text="Countdown finished",
            )
            dialog.format_secondary_text("Your timer reached zero.")
            dialog.run()
            dialog.destroy()
            self.timer_id = None
            return False
        self.remaining -= 1
        self.update_label()
        return True

    def update_label(self):
        mins = self.remaining // 60
        secs = self.remaining % 60
        self.label.set_markup(f"<span size='xx-large' weight='bold'>{mins:02d}:{secs:02d}</span>")


def main():
    win = CountdownWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
