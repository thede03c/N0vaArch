#!/usr/bin/env bash
set -euo pipefail

if ! command -v zenity >/dev/null 2>&1 && ! command -v kdialog >/dev/null 2>&1; then
  echo "zenity or kdialog is required."
  exit 1
fi

STATE_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/novaarch"
AUTO_FILE="${STATE_DIR}/control-center-autostart"
mkdir -p "${STATE_DIR}"
[[ -f "${AUTO_FILE}" ]] || echo "1" > "${AUTO_FILE}"

menu="$(
cat <<'EOF'
App Installer
Package Updates
Richer Monitor
NovaArch Tweaks
Wallpaper Scene
Wallpaper Manager
UI Customizer
Desktop Clock Widget
Countdown Timer
Open Trash
App Shortcuts and Pinning
Bluetooth
Display and Monitor
KDE System Settings
Network (nmtui)
Process Monitor (GUI)
Process Monitor (CLI)
Boot Branding Toggle
Open Settings Folder
Toggle Control Center Autostart
EOF
)"

choice="$(printf '%s\n' "${menu}" | /usr/local/bin/novaarch-dmenu --prompt 'NovaArch Control Center')" || exit 0
[[ -n "${choice:-}" ]] || exit 0

case "${choice}" in
  "App Installer")
    exec /usr/local/bin/novaarch-app-installer
    ;;
  "Package Updates")
    exec /usr/local/bin/novaarch-system-update
    ;;
  "Richer Monitor")
    exec /usr/local/bin/novaarch-monitor
    ;;
  "NovaArch Tweaks")
    exec /usr/local/bin/novaarch-tweaks
    ;;
  "Wallpaper Scene")
    exec /usr/local/bin/novaarch-wallpaper-selector
    ;;
  "Wallpaper Manager")
    exec /usr/local/bin/novaarch-wallpaper-manager
    ;;
  "UI Customizer")
    exec /usr/local/bin/novaarch-ui-customizer
    ;;
  "Desktop Clock Widget")
    exec /usr/local/bin/novaarch-desktop-clock
    ;;
  "Countdown Timer")
    exec /usr/local/bin/novaarch-countdown-timer
    ;;
  "Open Trash")
    exec /usr/local/bin/novaarch-open-trash
    ;;
  "App Shortcuts and Pinning")
    exec /usr/local/bin/novaarch-app-shortcuts
    ;;
  "Bluetooth")
    if command -v bluedevil-wizard >/dev/null 2>&1; then
      exec bluedevil-wizard
    fi
    exec /usr/local/bin/novaarch-ui-customizer
    ;;
  "Display and Monitor")
    if command -v kcmshell6 >/dev/null 2>&1; then
      exec kcmshell6 kcm_kscreen
    fi
    if command -v kcmshell5 >/dev/null 2>&1; then
      exec kcmshell5 kcm_kscreen
    fi
    exec /usr/local/bin/novaarch-ui-customizer
    ;;
  "KDE System Settings")
    exec /usr/local/bin/novaarch-ui-customizer
    ;;
  "Network (nmtui)")
    exec /usr/local/bin/novaarch-terminal --title "Network Manager" -- nmtui
    ;;
  "Process Monitor (GUI)")
    if command -v plasma-systemmonitor >/dev/null 2>&1; then
      exec plasma-systemmonitor
    fi
    exec /usr/local/bin/novaarch-terminal --title "btop" -- btop
    ;;
  "Process Monitor (CLI)")
    exec /usr/local/bin/novaarch-terminal --title "Process Monitor" -- btop
    ;;
  "Boot Branding Toggle")
    exec /usr/local/bin/novaarch-terminal --title "Boot Branding" -- sh -lc 'current="$(novaarch-plymouth-toggle status)"; if [[ "${current}" == "enabled" ]]; then sudo novaarch-plymouth-toggle off; else sudo novaarch-plymouth-toggle on; fi; echo; novaarch-plymouth-toggle status; read -rp "Press Enter to close..." _'
    ;;
  "Open Settings Folder")
    if command -v dolphin >/dev/null 2>&1; then
      exec dolphin "${HOME}/.config"
    fi
    exec /usr/local/bin/novaarch-terminal --title "Config" -- sh -lc "cd \"${HOME}/.config\" && ${SHELL:-bash}"
    ;;
  "Toggle Control Center Autostart")
    current="$(tr -d '\r\n' < "${AUTO_FILE}")"
    if [[ "${current}" == "1" ]]; then
      echo "0" > "${AUTO_FILE}"
      command -v notify-send >/dev/null 2>&1 && notify-send "NovaArch" "Control Center autostart disabled"
    else
      echo "1" > "${AUTO_FILE}"
      command -v notify-send >/dev/null 2>&1 && notify-send "NovaArch" "Control Center autostart enabled"
    fi
    ;;
esac
