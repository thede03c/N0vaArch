#!/usr/bin/env python3
import datetime
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, GLib


class ClockWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="NovaArch Clock")
        self.set_default_size(260, 120)
        self.set_border_width(12)
        self.set_keep_above(True)
        self.label = Gtk.Label()
        self.label.set_markup("<span size='xx-large' weight='bold'>--:--</span>")
        self.add(self.label)
        self.update()
        GLib.timeout_add_seconds(1, self.update)

    def update(self):
        now = datetime.datetime.now().strftime("%H:%M:%S\n%a %d %b")
        self.label.set_markup(f"<span size='xx-large' weight='bold'>{now}</span>")
        return True


def main():
    win = ClockWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
