#!/usr/bin/env bash
set -euo pipefail

if ! command -v zenity >/dev/null 2>&1 && ! command -v kdialog >/dev/null 2>&1; then
  echo "zenity or kdialog is required."
  exit 1
fi

choice="$(
cat <<'EOF' | /usr/local/bin/novaarch-dmenu --prompt 'NovaArch Optional Bundles'
Peripheral RGB / Device Control
Virtualization Host Tools
Privacy Browser Bundle
Install All Optional Bundles
EOF
)" || exit 0

[[ -n "${choice:-}" ]] || exit 0

pkgs=""
case "${choice}" in
  "Peripheral RGB / Device Control")
    pkgs="openrgb solaar piper liquidctl"
    ;;
  "Virtualization Host Tools")
    pkgs="virtualbox virtualbox-host-dkms dkms"
    ;;
  "Privacy Browser Bundle")
    pkgs="torbrowser-launcher"
    ;;
  "Install All Optional Bundles")
    pkgs="openrgb solaar piper liquidctl virtualbox virtualbox-host-dkms dkms torbrowser-launcher"
    ;;
  *)
    exit 0
    ;;
esac

exec /usr/local/bin/novaarch-terminal --title "NovaArch Optional Bundles" -- sh -lc "
  echo 'Installing optional packages...'
  sudo pacman -S --needed ${pkgs}
  echo
  echo 'Press Enter to close...'
  read -r _
"
