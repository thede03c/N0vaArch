#!/usr/bin/env bash
set -euo pipefail

src="${1:?Usage: novaarch-apply-start-icon /path-to-icon}"

[[ -f "${src}" ]] || { printf '%s not found.\n' "${src}" >&2; exit 1; }

STATE_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/novaarch"
ICON_RECORD="${STATE_DIR}/start-menu-icon"
dest_dir="${HOME}/.local/share/novaarch"
mkdir -p "${dest_dir}" "${STATE_DIR}"

ext="${src##*.}"
[[ "${ext}" == "${src}" ]] && ext="png"
basename="launcher-icon.${ext}"
cp -f "${src}" "${dest_dir}/${basename}"
printf '%s\n' "$(readlink -f "${dest_dir}/${basename}" 2>/dev/null || realpath "${dest_dir}/${basename}" 2>/dev/null || echo "${dest_dir}/${basename}")" >"${ICON_RECORD}"

command -v notify-send >/dev/null 2>&1 && notify-send "NovaArch" "Icon saved. On KDE Plasma: right-click the panel → Edit Panel, or open System Settings → Appearance to customize the launcher."
/usr/local/bin/novaarch-reload-waybar >/dev/null 2>&1 || true
