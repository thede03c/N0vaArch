#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/novaarch"
AUTO_FILE="${STATE_DIR}/welcome-autostart"
mkdir -p "${STATE_DIR}"
[[ -f "${AUTO_FILE}" ]] || echo "1" > "${AUTO_FILE}"

enabled="$(tr -d '\r\n' < "${AUTO_FILE}")"
[[ "${enabled}" == "1" ]] || exit 0

sleep 2
exec /usr/local/bin/novaarch-welcome
