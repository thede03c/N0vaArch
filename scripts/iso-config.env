ISO_NAME="novaarch"
ISO_LABEL="NOVAARCH_$(date +%Y%m)"
ISO_PUBLISHER="NovaArch Project"
ISO_APPLICATION="NovaArch Live/Rescue Environment"
ISO_VERSION="$(date +%Y.%m.%d)"
INSTALL_DIR="novaarch"

# Kernel choice:
# - linux (stock Arch)
# - linux-zen (good default for desktop/gaming)
# - linux-cachyos (requires additional repos, not enabled by default here)
KERNEL_PACKAGE="linux-zen"
KERNEL_HEADERS_PACKAGE="${KERNEL_PACKAGE}-headers"

# Kernel tracks:
# - zen: linux-zen + linux-lts fallback (recommended default)
# - cachy: linux-cachyos + linux-lts fallback
# - lts: linux-lts only (maximum stability)
KERNEL_TRACK="zen"

# Optional experimental edge track metadata for future module integration.
ENABLE_BLEEDING_EDGE_TRACK="0"
